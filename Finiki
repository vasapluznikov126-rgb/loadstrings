-- ========== НАСТРОЙКИ ==========
local ENLARGE_SIZE = 100000000000000000000000000000000000000000000      -- Размер увеличенного хитбокса
local NORMAL_SIZE = 2            -- Нормальный размер хитбокса
local ENLARGE_TRANSPARENCY = 0.7 -- Прозрачность для увеличенных
local NORMAL_TRANSPARENCY = 1    -- Полностью прозрачный для нормальных

_G.Enabled = true  -- true = скрипт работает

-- БЕЛЫЙ СПИСОК (игроки с НОРМАЛЬНЫМ хитбоксом)
local whitelist = {}

-- ========== ФУНКЦИЯ ПРИМЕНЕНИЯ ИЗМЕНЕНИЙ ==========
local function applyHitboxChanges()
    if not _G.Enabled then return end
    
    for _, target in pairs(Players:GetPlayers()) do
        if target ~= player then
            local isWhitelisted = false
            for _, name in ipairs(whitelist) do
                if name == target.Name then
                    isWhitelisted = true
                    break
                end
            end
            
            pcall(function()
                if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = target.Character.HumanoidRootPart
                    
                    if isWhitelisted then
                        -- В белом списке: НОРМАЛЬНЫЙ хитбокс
                        if hrp.Size ~= Vector3.new(NORMAL_SIZE, NORMAL_SIZE, NORMAL_SIZE) then
                            hrp.Size = Vector3.new(NORMAL_SIZE, NORMAL_SIZE, NORMAL_SIZE)
                            hrp.Transparency = NORMAL_TRANSPARENCY
                        end
                    else
                        -- НЕ в белом списке: БОЛЬШОЙ хитбокс
                        if hrp.Size ~= Vector3.new(ENLARGE_SIZE, ENLARGE_SIZE, ENLARGE_SIZE) then
                            hrp.Size = Vector3.new(ENLARGE_SIZE, ENLARGE_SIZE, ENLARGE_SIZE)
                            hrp.Transparency = ENLARGE_TRANSPARENCY
                            hrp.BrickColor = BrickColor.new("Really blue")
                            hrp.Material = Enum.Material.Neon
                            hrp.CanCollide = false
                        end
                    end
                end
            end)
        end
    end
end

