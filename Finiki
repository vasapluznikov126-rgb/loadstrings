local function updateWhitelistGUI()
    for _, child in pairs(whitelistScroll:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, name in ipairs(whitelist) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -10, 0, 32)
        frame.BackgroundColor3 = Color3.fromRGB(40, 55, 40)
        frame.BorderSizePixel = 1
        frame.BorderColor3 = Color3.fromRGB(80, 150, 80)
        frame.Parent = whitelistScroll
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -50, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = "🛡️ " .. name
        label.TextColor3 = Color3.fromRGB(150, 255, 150)
        label.TextSize = 12
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame
        
        local removeBtn = Instance.new("TextButton")
        removeBtn.Size = UDim2.new(0, 40, 1, -4)
        removeBtn.Position = UDim2.new(1, -45, 0, 2)
        removeBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        removeBtn.Text = "❌"
        removeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        removeBtn.TextSize = 14
        removeBtn.Font = Enum.Font.GothamBold
        removeBtn.Parent = frame
        
        removeBtn.MouseButton1Click:Connect(function()
            for i, wName in ipairs(whitelist) do
                if wName == name then
                    table.remove(whitelist, i)
                    break
                end
            end
            updateWhitelistGUI()
            updatePlayersGUI()
            print("❌ Removed from whitelist: " .. name)
        end)
    end
    
    if #whitelist == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, -10, 0, 40)
        empty.BackgroundTransparency = 1
        empty.Text = "📭 Empty"
        empty.TextColor3 = Color3.fromRGB(100, 150, 100)
        empty.TextSize = 12
        empty.Font = Enum.Font.Gotham
        empty.Parent = whitelistScroll
    end
    
    task.wait()
    whitelistScroll.CanvasSize = UDim2.new(0, 0, 0, whitelistLayout.AbsoluteContentSize.Y + 10)
end

local function updatePlayersGUI()
    for _, child in pairs(playersScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local allPlayers = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player then
            table.insert(allPlayers, v)
        end
    end
    table.sort(allPlayers, function(a, b) return a.Name < b.Name end)
    
    for _, target in ipairs(allPlayers) do
        local inWhitelist = false
        for _, wName in ipairs(whitelist) do
            if wName == target.Name then
                inWhitelist = true
                break
            end
        end
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 38)
        btn.BackgroundColor3 = inWhitelist and Color3.fromRGB(50, 80, 50) or Color3.fromRGB(80, 50, 50)
        btn.BorderSizePixel = 1
        btn.BorderColor3 = inWhitelist and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(200, 100, 100)
        btn.Text = (inWhitelist and "✅ " or "➕ ") .. target.Name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 13
        btn.Font = Enum.Font.Gotham
        btn.Parent = playersScroll
        
        if not inWhitelist then
            btn.MouseButton1Click:Connect(function()
                table.insert(whitelist, target.Name)
                updateWhitelistGUI()
                updatePlayersGUI()
                print("✅ Added to whitelist: " .. target.Name)
            end)
        end
    end
    
    if #allPlayers == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, -10, 0, 40)
        empty.BackgroundTransparency = 1
        empty.Text = "🌟 No other players"
        empty.TextColor3 = Color3.fromRGB(150, 100, 100)
        empty.TextSize = 12
        empty.Font = Enum.Font.Gotham
        empty.Parent = playersScroll
    end
    
    task.wait()
    playersScroll.CanvasSize = UDim2.new(0, 0, 0, playersLayout.AbsoluteContentSize.Y + 10)
end

-- КНОПКА ОЧИСТКИ
clearBtn.MouseButton1Click:Connect(function()
    for i = #whitelist, 1, -1 do
        table.remove(whitelist, i)
    end
    updateWhitelistGUI()
    updatePlayersGUI()
    print("🗑️ Whitelist cleared!")
end)

