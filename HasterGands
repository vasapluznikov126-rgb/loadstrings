-- Хранилище активных анимаций
local activeAnimations = {}
local animationRunning = false
local animationCoroutine = nil

-- Функция создания Attachment
local function createAttachment(parent, position, name)
    local oldAttachment = parent:FindFirstChild(name)
    if oldAttachment then
        oldAttachment:Destroy()
    end
    
    local attachment = Instance.new("Attachment")
    attachment.Parent = parent
    attachment.Name = name
    attachment.Position = Vector3.new(position[1], position[2], position[3])
    return attachment
end

-- Функция обновления позиции аттачмента с плавным переходом
local function updateAttachmentPosition(attachment, newPosition, duration)
    if not attachment then return end
    
    local startPos = attachment.Position
    local endPos = newPosition
    local startTime = tick()
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        local elapsed = tick() - startTime
        local alpha = math.min(1, elapsed / duration)
        
        -- Плавная интерполяция
        local easedAlpha = alpha * alpha * (3 - 2 * alpha)
        
        attachment.Position = startPos:Lerp(endPos, easedAlpha)
        
        if alpha >= 1 then
            connection:Disconnect()
        end
    end)
end

-- Анимация позиций аттачментов
local function animateAttachments(attachments)
    if animationRunning then return end
    animationRunning = true
    
    -- Сохраняем оригинальные позиции
    local originalPosValues = {}
    for name, attach in pairs(attachments) do
        originalPosValues[name] = attach.Position
    end
    
    while animationRunning do
        -- Фаза 1: +1 к Y координате
        statusLabel.Text = "Статус: Анимация - подъем (+1)..."
        for name, attach in pairs(attachments) do
            local origPos = originalPosValues[name]
            local newPos = Vector3.new(origPos.X, origPos.Y, origPos.Z - 1)
            updateAttachmentPosition(attach, newPos, 0.3)
        end
        
        wait(0.5)
        if not animationRunning then break end
        
        -- Фаза 2: -2 к Y координате (всего -1 от оригинала)
        statusLabel.Text = "Статус: Анимация - опускание (-2)..."
        for name, attach in pairs(attachments) do
            local origPos = originalPosValues[name]
            -- От текущей позиции (которая orig.Y + 1) опускаем на 2, получаем orig.Y - 1
            local currentPos = attach.Position
            local newPos = Vector3.new(origPos.X, origPos.Y, origPos.Z + 1)
            updateAttachmentPosition(attach, newPos, 0.3)
        end
        
        wait(0.5)
        if not animationRunning then break end
        
        -- Возврат к оригинальным позициям
        statusLabel.Text = "Статус: Анимация - возврат..."
        for name, attach in pairs(attachments) do
            local origPos = originalPosValues[name]
            updateAttachmentPosition(attach, origPos, 0.3)
        end
        
        wait(0.5)
        if not animationRunning then break end
    end
    
    -- Гарантированный возврат к оригинальным позициям при остановке
    if not animationRunning then
        statusLabel.Text = "Статус: Остановлена (возврат к исходным)"
        for name, attach in pairs(attachments) do
            local origPos = originalPosValues[name]
            attach.Position = origPos
        end
    end
    
    animationRunning = false
    statusLabel.Text = "Статус: Остановлена"
end

-- Функция привязки Align к аттачментам
local function setupAlignsForHand(handModel, targetAttachment)
    if not handModel or not targetAttachment then
        return false
    end
    
    local handRootPart = handModel:FindFirstChild("HumanoidRootPart")
    if not handRootPart then
        return false
    end
    
    local mainAttach = handRootPart:FindFirstChild("MainAttach")
    if not mainAttach then
        return false
    end
    
    local alignPosition = mainAttach:FindFirstChild("AlignPosition")
    local alignOrientation = mainAttach:FindFirstChild("AlignOrientation")
    
    if not alignPosition or not alignOrientation then
        return false
    end
    
    alignPosition.Attachment1 = targetAttachment
    alignOrientation.Attachment1 = targetAttachment
    
    return true
end

-- Основная функция для выбранного игрока
local function setupForPlayer(targetPlayer)
    if not targetPlayer then
        warn("Игрок не выбран!")
        return
    end
    
    -- Останавливаем текущую анимацию если есть
    if animationRunning then
        animationRunning = false
        if animationCoroutine and coroutine.status(animationCoroutine) ~= "dead" then
            coroutine.close(animationCoroutine)
        end
        wait(0.2)
    end
    
    local targetCharacter = targetPlayer.Character
    if not targetCharacter then
        local notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 250, 0, 40)
        notification.Position = UDim2.new(0.5, -125, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        notification.Text = "⚠️ " .. targetPlayer.Name .. " не в игре!"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    local humanoidRootPart = targetCharacter:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        warn("HumanoidRootPart не найден у " .. targetPlayer.Name)
        return
    end
    
    local gasterHands = targetCharacter:FindFirstChild("GasterHands")
    if not gasterHands then
        local notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 300, 0, 40)
        notification.Position = UDim2.new(0.5, -150, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        notification.Text = "⚠️ Папка GasterHands не найдена у " .. targetPlayer.Name
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    local successCount = 0
    local attachments = {}
    
    -- Создаем аттачменты и сохраняем их
    for _, data in pairs(originalPositions) do
        local attachName = data[4]
        local attachment = createAttachment(humanoidRootPart, {data[1], data[2], data[3]}, attachName)
        attachments[attachName] = attachment
        
        -- Привязываем руки
        for handName, targetAttachName in pairs(handToAttach) do
            if targetAttachName == attachName then
                local handModel = gasterHands:FindFirstChild(handName)
                if handModel then
                    if setupAlignsForHand(handModel, attachment) then
                        successCount = successCount + 1
                    end
                end
                break
            end
        end
    end
    
    -- Сохраняем аттачменты для анимации
    activeAnimations[targetPlayer.Name] = attachments
    
    -- Уведомление
    local resultNotify = Instance.new("TextLabel")
    resultNotify.Size = UDim2.new(0, 350, 0, 50)
    resultNotify.Position = UDim2.new(0.5, -175, 0.7, 0)
    resultNotify.BackgroundTransparency = 0.2
    resultNotify.TextColor3 = Color3.fromRGB(255, 255, 255)
    resultNotify.TextSize = 14
    resultNotify.Font = Enum.Font.Gotham
    resultNotify.Parent = screenGui
    
    if successCount == 7 then
        resultNotify.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        resultNotify.Text = "✅ Успех! 7 рук привязаны. Нажми 'Запустить анимацию'"
        resultNotify.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        resultNotify.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
        resultNotify.Text = "⚠️ Привязано " .. successCount .. "/7 рук, но анимация будет работать"
    end
    
    game:GetService("Debris"):AddItem(resultNotify, 3)
    
    -- Автоматически выбираем этого игрока для анимации
    selectedPlayerForAnimation = targetPlayer
    
    print(string.format("✅ Готово для %s: %d/7 рук привязано", targetPlayer.Name, successCount))
end

-- Запуск анимации для выбранного игрока
local function startAnimation()
    if not selectedPlayerForAnimation then
        local notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 300, 0, 40)
        notification.Position = UDim2.new(0.5, -150, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        notification.Text = "⚠️ Сначала выбери игрока из списка!"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    local attachments = activeAnimations[selectedPlayerForAnimation.Name]
    if not attachments then
        local notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 300, 0, 40)
        notification.Position = UDim2.new(0.5, -150, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        notification.Text = "❌ Аттачменты не найдены! Выбери игрока заново"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    if animationRunning then
        notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 250, 0, 40)
        notification.Position = UDim2.new(0.5, -125, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        notification.Text = "⚠️ Анимация уже запущена!"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    animationCoroutine = coroutine.create(function()
        animateAttachments(attachments)
    end)
    coroutine.resume(animationCoroutine)
end

-- Остановка анимации
local function stopAnimation()
    if not animationRunning then
        local notification = Instance.new("TextLabel")
        notification.Size = UDim2.new(0, 250, 0, 40)
        notification.Position = UDim2.new(0.5, -125, 0.8, 0)
        notification.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        notification.Text = "⚠️ Анимация и так остановлена!"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.Font = Enum.Font.Gotham
        notification.BackgroundTransparency = 0.2
        notification.Parent = screenGui
        game:GetService("Debris"):AddItem(notification, 2)
        return
    end
    
    animationRunning = false
    statusLabel.Text = "Статус: Остановка..."
end

