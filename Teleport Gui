-- ========== ФУНКЦИИ ОБНОВЛЕНИЯ КАНВАСА ==========
local function updatePlayersCanvas()
    task.wait()
    local contentHeight = playersList.AbsoluteContentSize.Y
    playersContainer.CanvasSize = UDim2.new(0, 0, 0, math.max(contentHeight + 10, playersContainer.AbsoluteSize.Y))
end

local function updateLocationsCanvas()
    task.wait()
    local contentHeight = locationsList.AbsoluteContentSize.Y
    locationsContainer.CanvasSize = UDim2.new(0, 0, 0, math.max(contentHeight + 10, locationsContainer.AbsoluteSize.Y))
end

-- ========== ОБНОВЛЕНИЕ СПИСКА ИГРОКОВ ==========
local function refreshPlayersList()
    -- Удаляем все кнопки
    for _, btn in pairs(playerButtons) do
        btn:Destroy()
    end
    playerButtons = {}
    
    if playersEmptyMsg then
        playersEmptyMsg:Destroy()
        playersEmptyMsg = nil
    end
    
    local allPlayers = Players:GetPlayers()
    local playersListData = {}
    
    for _, target in ipairs(allPlayers) do
        if target ~= player then
            table.insert(playersListData, target)
        end
    end
    
    table.sort(playersListData, function(a, b)
        return a.Name < b.Name
    end)
    
    if #playersListData > 0 then
        for _, target in ipairs(playersListData) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 55)
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
            btn.BorderSizePixel = 2
            btn.BorderColor3 = Color3.fromRGB(0, 200, 255)
            btn.Text = "👤 " .. target.Name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 18
            btn.Font = Enum.Font.GothamBold
            btn.Parent = playersContainer
            
            if target.Team then
                local teamIndicator = Instance.new("TextLabel")
                teamIndicator.Size = UDim2.new(0, 80, 1, 0)
                teamIndicator.Position = UDim2.new(1, -85, 0, 0)
                teamIndicator.BackgroundTransparency = 1
                teamIndicator.Text = "[" .. target.Team.Name .. "]"
                teamIndicator.TextColor3 = Color3.fromRGB(150, 200, 255)
                teamIndicator.TextSize = 12
                teamIndicator.Font = Enum.Font.Gotham
                teamIndicator.TextXAlignment = Enum.TextXAlignment.Right
                teamIndicator.Parent = btn
            end
            
            -- Эффект наведения
            btn.MouseEnter:Connect(function()
                btn.BackgroundColor3 = Color3.fromRGB(80, 80, 120)
            end)
            
            btn.MouseLeave:Connect(function()
                btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
            end)
            
            -- Телепорт при нажатии
            btn.MouseButton1Click:Connect(function()
                teleportToPlayer(target)
            end)
            
            playerButtons[target.Name] = btn
        end
    else
        playersEmptyMsg = Instance.new("TextLabel")
        playersEmptyMsg.Size = UDim2.new(1, 0, 0, 60)
        playersEmptyMsg.BackgroundTransparency = 1
        playersEmptyMsg.Text = "🌟 NO PLAYERS 🌟"
        playersEmptyMsg.TextColor3 = Color3.fromRGB(150, 150, 200)
        playersEmptyMsg.TextSize = 16
        playersEmptyMsg.Font = Enum.Font.Gotham
        playersEmptyMsg.Parent = playersContainer
    end
    
    updatePlayersCanvas()
end

-- ========== ОБНОВЛЕНИЕ СПИСКА ЛОКАЦИЙ ==========
local function refreshLocationsList()
    -- Очищаем контейнер
    for _, child in pairs(locationsContainer:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    -- Создаём кнопки для каждой локации
    for _, loc in ipairs(teleportLocations) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 70)
        btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
        btn.BorderSizePixel = 2
        btn.BorderColor3 = loc.color
        btn.Parent = locationsContainer
        
        -- Название локации
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.Position = UDim2.new(0, 10, 0, 5)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = loc.name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 20
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = btn
        
        -- Координаты
        local coordsLabel = Instance.new("TextLabel")
        coordsLabel.Size = UDim2.new(1, 0, 0.4, 0)
        coordsLabel.Position = UDim2.new(0, 10, 0.5, 0)
        coordsLabel.BackgroundTransparency = 1
        coordsLabel.Text = string.format("📍 X: %.1f  Y: %.1f  Z: %.1f", loc.position.X, loc.position.Y, loc.position.Z)
        coordsLabel.TextColor3 = Color3.fromRGB(150, 200, 255)
        coordsLabel.TextSize = 13
        coordsLabel.Font = Enum.Font.Gotham
        coordsLabel.TextXAlignment = Enum.TextXAlignment.Left
        coordsLabel.Parent = btn
        
        -- Иконка телепорта
        local iconLabel = Instance.new("TextLabel")
        iconLabel.Size = UDim2.new(0, 50, 1, 0)
        iconLabel.Position = UDim2.new(1, -60, 0, 0)
        iconLabel.BackgroundTransparency = 1
        iconLabel.Text = "🚀"
        iconLabel.TextColor3 = loc.color
        iconLabel.TextSize = 30
        iconLabel.Font = Enum.Font.Gotham
        iconLabel.Parent = btn
        
        -- Эффект наведения
        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(80, 80, 120)
            iconLabel.Text = "✨"
        end)
        
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
            iconLabel.Text = "🚀"
        end)
        
        -- Телепорт при нажатии
        btn.MouseButton1Click:Connect(function()
            teleportToPosition(loc.position)
            -- Визуальный фидбек
            local originalText = btn.Text
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
            task.wait(0.2)
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
        end)
    end
    
    updateLocationsCanvas()
end

