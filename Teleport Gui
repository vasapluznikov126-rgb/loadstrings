-- ФУНКЦИЯ ОБНОВЛЕНИЯ КАНВАСА
local function updateCanvas()
    task.wait()
    local contentHeight = uiList.AbsoluteContentSize.Y
    listFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(contentHeight + 10, listFrame.AbsoluteSize.Y))
end

-- ФУНКЦИЯ ОБНОВЛЕНИЯ СПИСКА
local function refreshPlayerList()
    for _, btn in pairs(playerButtons) do
        btn:Destroy()
    end
    playerButtons = {}
    
    local allPlayers = Players:GetPlayers()
    local playersList = {}
    
    for _, target in ipairs(allPlayers) do
        if target ~= player then
            table.insert(playersList, target)
        end
    end
    
    table.sort(playersList, function(a, b)
        return a.Name < b.Name
    end)
    
    for _, target in ipairs(playersList) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 55)
        btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
        btn.BorderSizePixel = 2
        btn.BorderColor3 = Color3.fromRGB(0, 200, 255)
        btn.Text = "👤 " .. target.Name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 18
        btn.Font = Enum.Font.GothamBold
        btn.Parent = listFrame
        
        if target.Team then
            local teamIndicator = Instance.new("TextLabel")
            teamIndicator.Size = UDim2.new(0, 80, 1, 0)
            teamIndicator.Position = UDim2.new(1, -85, 0, 0)
            teamIndicator.BackgroundTransparency = 1
            teamIndicator.Text = "[" .. target.Team.Name .. "]"
            teamIndicator.TextColor3 = Color3.fromRGB(150, 200, 255)
            teamIndicator.TextSize = 12
            teamIndicator.Font = Enum.Font.Gotham
            teamIndicator.TextXAlignment = Enum.TextXAlignment.Right
            teamIndicator.Parent = btn
        end
        
        -- Эффект наведения
        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(80, 80, 120)
        end)
        
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 80)
        end)
        
        -- ТЕЛЕПОРТ ПРИ НАЖАТИИ
        btn.MouseButton1Click:Connect(function()
            teleportTo(target)
        end)
        
        playerButtons[target.Name] = btn
    end
    
    if next(playerButtons) == nil then
        local emptyMsg = Instance.new("TextLabel")
        emptyMsg.Size = UDim2.new(1, 0, 0, 60)
        emptyMsg.BackgroundTransparency = 1
        emptyMsg.Text = "🌟 NO PLAYERS 🌟"
        emptyMsg.TextColor3 = Color3.fromRGB(150, 150, 200)
        emptyMsg.TextSize = 16
        emptyMsg.Font = Enum.Font.Gotham
        emptyMsg.Parent = listFrame
    end
    
    updateCanvas()
end

