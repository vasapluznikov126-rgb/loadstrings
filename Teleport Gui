-- ФУНКЦИЯ ТЕЛЕПОРТАЦИИ К ИГРОКУ
local function teleportToPlayer(targetPlayer)
    if not targetPlayer then return false end
    
    local targetCharacter = targetPlayer.Character
    if not targetCharacter then return false end
    
    local targetHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return false end
    
    local myCharacter = player.Character
    if not myCharacter then return false end
    
    local myHRP = myCharacter:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end
    
    local offset = Vector3.new(-4, 0, 0)
    myHRP.CFrame = targetHRP.CFrame * CFrame.new(offset)
    
    return true
end

-- ФУНКЦИЯ ТЕЛЕПОРТАЦИИ ПО КООРДИНАТАМ
local function teleportToPosition(position)
    local myCharacter = player.Character
    if not myCharacter then return false end
    
    local myHRP = myCharacter:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end
    
    myHRP.CFrame = CFrame.new(position)
    return true
end

