-- Функция телепортации
local function teleportTo(position, lookUp)
    local character = LocalPlayer.Character
    if not character then
        infoLabel.Text = "Ошибка: Персонаж не найден!"
        infoLabel.TextColor3 = Color3.new(1, 0, 0)
        return
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    
    if not humanoidRootPart or not humanoid then
        infoLabel.Text = "Ошибка: HumanoidRootPart не найден!"
        infoLabel.TextColor3 = Color3.new(1, 0, 0)
        return
    end
    
    if lookUp then
        -- Телепорт с направлением вверх (для кнопки B)
        local lookPoint = position + settings.lookDirection * 100
        humanoidRootPart.CFrame = CFrame.lookAt(position, lookPoint)
        
        -- Дополнительная фиксация торса
        local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        if torso then
            torso.CFrame = CFrame.lookAt(torso.Position, lookPoint)
        end
        
        -- Коррекция направления
        humanoid.AutoRotate = false
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if humanoidRootPart and humanoidRootPart.Parent then
                local currentLook = humanoidRootPart.CFrame.LookVector
                if (currentLook - settings.lookDirection).Magnitude > 0.1 then
                    humanoidRootPart.CFrame = CFrame.lookAt(humanoidRootPart.Position, lookPoint)
                end
            else
                connection:Disconnect()
            end
        end)
        
        task.delay(2, function()
            if connection then
                connection:Disconnect()
                humanoid.AutoRotate = true
            end
        end)
        
        infoLabel.Text = string.format("Телепорт на B: (%.0f, %.0f, %.0f) [ВВЕРХ]", 
            position.X, position.Y, position.Z)
    else
        -- Обычный телепорт без изменения направления
        humanoidRootPart.CFrame = CFrame.new(position)
        infoLabel.Text = string.format("Телепорт на: (%.0f, %.0f, %.0f)", 
            position.X, position.Y, position.Z)
    end
    
    infoLabel.TextColor3 = Color3.new(0, 1, 0)
    
    -- Звук
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxasset://sounds/action_footsteps_plastic.mp3"
    sound.Parent = character
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
    
    task.delay(2, function()
        infoLabel.Text = "Кликните на игрока для телепортации (Y сохраняется)"
        infoLabel.TextColor3 = Color3.new(1, 1, 0)
    end)
end

-- Функция обновления списка игроков
local function updatePlayerList()
    -- Очищаем старые кнопки
    for _, button in pairs(playerButtons) do
        button:Destroy()
    end
    playerButtons = {}
    
    -- Получаем всех игроков кроме себя
    local otherPlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(otherPlayers, player)
        end
    end
    
    -- Сортируем по имени
    table.sort(otherPlayers, function(a, b)
        return a.Name < b.Name
    end)
    
    -- Создаем кнопки для каждого игрока
    for _, player in ipairs(otherPlayers) do
        local playerButton = Instance.new("TextButton")
        playerButton.Name = "PlayerButton_" .. player.Name
        playerButton.Parent = scrollFrame
        playerButton.Size = UDim2.new(0.95, 0, 0, 45)
        playerButton.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
        playerButton.AutoButtonColor = true
        playerButton.Text = ""
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = playerButton
        
        -- Индикатор онлайн
        local statusDot = Instance.new("Frame")
        statusDot.Parent = playerButton
        statusDot.Size = UDim2.new(0, 8, 0, 8)
        statusDot.Position = UDim2.new(0, 8, 0.5, -4)
        statusDot.BackgroundColor3 = Color3.new(0, 1, 0)
        statusDot.BorderSizePixel = 0
        
        local dotCorner = Instance.new("UICorner")
        dotCorner.CornerRadius = UDim.new(1, 0)
        dotCorner.Parent = statusDot
        
        -- Имя игрока
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Parent = playerButton
        nameLabel.Size = UDim2.new(0.45, 0, 0.5, 0)
        nameLabel.Position = UDim2.new(0, 20, 0, 2)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = player.Name
        nameLabel.TextColor3 = Color3.new(1, 1, 1)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        -- Координаты игрока
        local coordsLabel = Instance.new("TextLabel")
        coordsLabel.Parent = playerButton
        coordsLabel.Size = UDim2.new(0.45, 0, 0.5, 0)
        coordsLabel.Position = UDim2.new(0, 20, 0, 22)
        coordsLabel.BackgroundTransparency = 1
        coordsLabel.TextColor3 = Color3.new(0.6, 0.6, 1)
        coordsLabel.TextSize = 11
        coordsLabel.Font = Enum.Font.Gotham
        coordsLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        -- Расстояние до игрока
        local distanceLabel = Instance.new("TextLabel")
        distanceLabel.Parent = playerButton
        distanceLabel.Size = UDim2.new(0.25, 0, 1, 0)
        distanceLabel.Position = UDim2.new(0.45, 0, 0, 0)
        distanceLabel.BackgroundTransparency = 1
        distanceLabel.TextColor3 = Color3.new(0.5, 0.5, 1)
        distanceLabel.TextSize = 12
        distanceLabel.Font = Enum.Font.Gotham
        
        -- Кнопка телепорта
        local tpIcon = Instance.new("TextLabel")
        tpIcon.Parent = playerButton
        tpIcon.Size = UDim2.new(0.2, 0, 1, 0)
        tpIcon.Position = UDim2.new(0.7, 0, 0, 0)
        tpIcon.BackgroundTransparency = 1
        tpIcon.Text = "↗"
        tpIcon.TextColor3 = Color3.new(0, 1, 0)
        tpIcon.TextSize = 24
        tpIcon.Font = Enum.Font.GothamBold
        
        -- Функция обновления информации об игроке
        local function updatePlayerInfo()
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local playerPos = player.Character.HumanoidRootPart.Position
                coordsLabel.Text = string.format("X:%.0f Z:%.0f", playerPos.X, playerPos.Z)
                
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
                    local dist = (myPos - playerPos).Magnitude
                    distanceLabel.Text = string.format("%.0f st", dist)
                end
            else
                coordsLabel.Text = "?"
                distanceLabel.Text = "?"
            end
        end
        
        -- Обновляем информацию каждую секунду
        local heartbeatConn
        heartbeatConn = RunService.Heartbeat:Connect(function()
            if playerButton and playerButton.Parent then
                updatePlayerInfo()
            else
                heartbeatConn:Disconnect()
            end
        end)
        
        -- Обработчик клика - ТЕЛЕПОРТАЦИЯ К ИГРОКУ С СОХРАНЕНИЕМ Y
        playerButton.MouseButton1Click:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    -- Берем X и Z игрока, но сохраняем свою Y
                    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
                    local targetPos = player.Character.HumanoidRootPart.Position
                    
                    -- Создаем новую позицию с X и Z игрока, но с моей Y
                    local teleportPos = Vector3.new(targetPos.X, myPos.Y, targetPos.Z)
                    
                    teleportTo(teleportPos, false)  -- false = обычный телепорт без поворота
                    
                    -- Визуальный эффект нажатия
                    playerButton.BackgroundColor3 = Color3.new(0, 0.5, 0)
                    task.delay(0.2, function()
                        if playerButton and playerButton.Parent then
                            playerButton.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
                        end
                    end)
                    
                    -- Показываем что сохранили Y
                    infoLabel.Text = string.format("Телепорт к %s: Y=%.0f сохранена", player.Name, myPos.Y)
                    infoLabel.TextColor3 = Color3.new(0, 1, 0)
                else
                    infoLabel.Text = "Игрок " .. player.Name .. " не имеет персонажа!"
                    infoLabel.TextColor3 = Color3.new(1, 0, 0)
                end
            else
                infoLabel.Text = "У вас нет персонажа!"
                infoLabel.TextColor3 = Color3.new(1, 0, 0)
            end
            
            task.delay(2, function()
                infoLabel.Text = "Кликните на игрока для телепортации (Y сохраняется)"
                infoLabel.TextColor3 = Color3.new(1, 1, 0)
            end)
        end)
        
        table.insert(playerButtons, playerButton)
    end
end

